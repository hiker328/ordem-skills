# Credenciais usadas pelas skills. Copie para `.env` e preencha.
# NUNCA comite o .env (já está no .gitignore). Veja como obter cada uma em
# .claude/skills/<skill>/references/credenciais.md

# --- Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=https://evolution.seudominio.com.br
EVOLUTION_APIKEY=
EVOLUTION_INSTANCE=

# --- HuggingFace (diarização no WhisperX) ---
# Token "read" + aceitar termos de pyannote/speaker-diarization-community-1
HF_TOKEN=

# --- OpenAI (apenas fallback de transcrição, opcional, com custo) ---
OPENAI_API_KEY=
